# Digital Trade Mobile — environment variables.
# Copy to `.env` (or `.env.dev` / `.env.staging` / `.env.prod`) and adjust per flavor.

# Base URL of the dt-backend API.
API_BASE_URL=https://dev-trade-api.digital-group.uz

# Root path served under `${API_BASE_URL}` for static files.
API_FILE_URL=https://dev-trade-api.digital-group.uz

# Shown in app title / splash.
APP_NAME=Digital Trade

# If true, prints HTTP + navigation logs. Force-disable in prod builds.
ENABLE_LOGGING=true
